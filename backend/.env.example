# =============================================================================
# 成长小岛 — 后端环境变量模板
# 使用方法：复制为 .env 后按实际环境修改
#   cp .env.example .env        # Linux / macOS
#   copy .env.example .env      # Windows CMD
# =============================================================================

# --- 应用基础 ---
PROJECT_NAME=成长小岛
# 开发环境 true；Linux 生产部署建议 false
DEBUG=true

# --- PostgreSQL（必填）---
# 格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# 本机开发请使用独立库 island，避免与远程服务器上的 stday 库混用：
DATABASE_URL=postgresql+asyncpg://postgres:your_password@127.0.0.1:5432/island
# 远程/生产环境可继续使用 stday 等既有库名，只需修改主机与库名

# --- JWT 认证（必填）---
# 生产环境务必替换为随机长字符串（≥32 字符）
JWT_SECRET_KEY=please-change-this-secret-key-in-production
JWT_ALGORITHM=HS256
# Token 有效期（分钟），默认 5256000 ≈ 10 年（客户端本地持久登录）
JWT_EXPIRE_MINUTES=5256000

# --- 千问 / DashScope（AI 功能必填）---
# 在 https://dashscope.console.aliyun.com/ 获取 API Key
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 对话模型（故事生成等长文本）
QWEN_CHAT_MODEL=qwen-plus
# 短交互模型（心情分析、小人演出等）；兼容旧名 QWEN_MOOD_REPORT_MODEL
QWEN_FAST_MODEL=qwen-flash
# QWEN_MOOD_REPORT_MODEL=qwen-flash

QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_ASR_MODEL=paraformer-v2
# 语音转写：DashScope 需通过公网 URL 拉取录音。生产环境填后端对外地址（无尾斜杠）
# 例：PUBLIC_API_BASE_URL=https://api.your-domain.com
# 未配置时将录音上传至 DashScope 临时 OSS（限 100 QPS，适合开发/小规模）
PUBLIC_API_BASE_URL=

QWEN_T2I_MODEL=wan2.5-t2i-preview
QWEN_I2V_MODEL=wan2.5-i2v-preview

# 异步 AI 任务轮询（文生图、图生视频）
QWEN_TASK_POLL_INTERVAL_SEC=3
QWEN_TASK_POLL_TIMEOUT_SEC=300

# --- Linux 运行时（可选，供 deploy/start.sh / systemd 使用，非 pydantic 配置项）---
# UVICORN_HOST=0.0.0.0
# UVICORN_PORT=9000
# UVICORN_WORKERS=2

# --- Redis 认证限流（推荐生产开启）---
# 本机开发无 Redis 时可设 RATE_LIMIT_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_MAX_CONNECTIONS=20
RATE_LIMIT_ENABLED=true

# 应用层限流（Nginx 入口另有第一道限流，见 deploy/nginx/）
# 登录：每 IP 10 次/分钟，每用户名 5 次/分钟
AUTH_LOGIN_IP_LIMIT=10
AUTH_LOGIN_IP_WINDOW_SEC=60
AUTH_LOGIN_USER_LIMIT=5
AUTH_LOGIN_USER_WINDOW_SEC=60
# 注册：每 IP 3 次/小时
AUTH_REGISTER_IP_LIMIT=3
AUTH_REGISTER_IP_WINDOW_SEC=3600
# 连续登录失败 5 次锁定 15 分钟
AUTH_LOGIN_FAIL_LOCK_COUNT=5
AUTH_LOGIN_FAIL_LOCK_SEC=900
