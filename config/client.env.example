# =============================================================================
# Flutter 客户端环境变量参考（编译时注入，非运行时 .env 文件）
# 学生端 stday / 教师端 teacher_app 共用同一变量名
# =============================================================================

# 后端 API 根地址（不含尾部斜杠）
# 当前部署服务器见 config/server.env
API_BASE_URL=http://39.106.134.222:8000

# --- 当前服务器 ---
# 公网（外网 / Windows 本地打包 / 校外客户端）：
#   API_BASE_URL=http://39.106.134.222:8000
#
# 私有 IP（同一阿里云 VPC 内网）：
#   API_BASE_URL=http://172.25.19.38:8000
#
# 本机开发（后端也在本机）：
#   API_BASE_URL=http://127.0.0.1:8000
#
# Android 模拟器访问本机后端：
#   API_BASE_URL=http://10.0.2.2:8000
#
# --- 快捷构建（已写好公网地址）---
#   stday/build_release_server.bat
#   teacher_app/build_release_server.bat
#
# --- 手动注入 ---
#   flutter build windows --release --dart-define=API_BASE_URL=http://39.106.134.222:8000
#   stday/run_windows.ps1 -ApiBaseUrl http://39.106.134.222:8000
